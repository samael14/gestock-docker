# GESTOCK — Variables d environnement
# Copiez ce fichier en .env et remplissez toutes les valeurs
#   cp .env.example .env

# Mot de passe PostgreSQL (min. 16 caracteres)
DB_PASSWORD=changeme_strong_password_here

# Secrets JWT — generez avec : openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret_minimum_32_chars
JWT_REFRESH_SECRET=changeme_refresh_secret_minimum_32_chars

# Mot de passe du compte admin cree au premier demarrage
ADMIN_PASSWORD=Admin@2024!

# URL acces (IP ou domaine du serveur)
CORS_ORIGIN=http://your-server-ip-or-domain

# Port HTTP expose (defaut : 80)
FRONTEND_PORT=80

# ── SMTP (optionnel) ────────────────────────────────────────────
# Laisser vide = emails desactives.
# La fonction "Ouvrir dans ma messagerie" fonctionne toujours sans SMTP.
# SMTP_HOST=smtp.monentreprise.fr
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=gestock@monentreprise.fr
# SMTP_PASS=mot_de_passe_smtp
# SMTP_FROM=GESTOCK <gestock@monentreprise.fr>
# SMTP_REJECT_UNAUTHORIZED=true

# ── GLPI (optionnel) ────────────────────────────────────────────
# Nom de domaine (SANS http://) de votre serveur GLPI.
# Laissez vide si vous n utilisez pas GLPI.
# GLPI_HOST=glpi.monentreprise.fr
