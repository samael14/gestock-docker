# ─────────────────────────────────────────────────────────────────
# GESTOCK — Variables d'environnement
# Copiez ce fichier en .env et remplissez toutes les valeurs
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# Mot de passe PostgreSQL (min. 16 caractères recommandé)
DB_PASSWORD=changeme_strong_password_here

# Secrets JWT (chaînes aléatoires, min. 32 caractères chacune)
# Générez-les avec : openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret_minimum_32_chars
JWT_REFRESH_SECRET=changeme_refresh_secret_minimum_32_chars

# Durées de validité des tokens (optionnel — valeurs par défaut indiquées)
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_EXPIRES=7d

# Mot de passe du compte admin créé au premier démarrage
ADMIN_PASSWORD=Admin@2024!

# URL d'accès à l'application (adresse IP ou nom de domaine du serveur)
# Exemples : http://192.168.1.100  ou  https://gestock.monentreprise.fr
CORS_ORIGIN=http://your-server-ip-or-domain

# Port HTTP exposé (défaut : 80)
FRONTEND_PORT=80

# Nombre de rounds bcrypt pour le hachage des mots de passe (défaut : 12)
# BCRYPT_ROUNDS=12
